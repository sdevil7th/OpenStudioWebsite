# Hashed JS/CSS/image assets — safe to cache 1 year (Vite fingerprints filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — never cache (SPA routing requires always-fresh index.html)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Sitemap and robots — refresh daily
/sitemap.xml
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400
/releases/ai-runtime/latest.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
/releases/ai-runtime/stable/latest.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
